# ==============================================================================
#  CORE DJANGO SETTINGS
# ==============================================================================
# IMPORTANT: Generate a new secret key for production. You can use:
# python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
SECRET_KEY="django-insecure-prod-key-replace-this-with-a-real-one"
DEBUG=False
ALLOWED_HOSTS=onrender.com,localhost,127.0.0.1
# For Render, you can also use '*' and rely on the proxy for host header validation.
# ALLOWED_HOSTS=*
 
# ==============================================================================
#  DATABASE
# ==============================================================================
# Render will provide this URL automatically as an environment variable.
# For local development, you can keep it as SQLite.
DATABASE_URL="postgres://user:password@host:port/dbname"
 
# ==============================================================================
#  CORS & CSRF
# ==============================================================================
# Add your frontend's Render URL here.
CORS_ALLOWED_ORIGINS="http://localhost:3000,http://127.0.0.1:3000,https://your-frontend-app.onrender.com"
CSRF_TRUSTED_ORIGINS="http://localhost:3000,http://127.0.0.1:3000,https://your-frontend-app.onrender.com"